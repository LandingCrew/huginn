# Auto detect text files and perform LF normalization
* text=auto

# Source files - enforce LF for consistency across platforms
*.cpp text eol=lf
*.h text eol=lf
*.hpp text eol=lf
*.c text eol=lf
*.inl text eol=lf

# CMake files
*.cmake text eol=lf
CMakeLists.txt text eol=lf

# Config/data files
*.json text eol=lf
*.xml text eol=lf
*.ini text eol=lf
*.toml text eol=lf
*.yaml text eol=lf
*.yml text eol=lf

# Documentation
*.md text eol=lf
*.txt text eol=lf

# Scripts
*.sh text eol=lf
*.ps1 text eol=crlf
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary files - no conversion
*.dll binary
*.exe binary
*.pdb binary
*.lib binary
*.obj binary
*.png binary
*.jpg binary
*.ico binary
*.bsa binary
*.esp binary
*.esm binary
