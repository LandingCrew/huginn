<?xml version="1.0" encoding="iso-8859-1"?>
<!--
  Intuition Widget - swfmill project definition
  Builds the SWF shell with library symbols.
  MTASC then injects compiled AS2 bytecode.

  Build: swfmill simple intuition.xml Intuition.swf
         mtasc -cp . -swf Intuition.swf Intuition.as
-->
<movie width="1280" height="720" framerate="24" version="8">
  <background color="#000000"/>
  <frame>
    <library>
      <!-- Main widget clip - linked to Intuition.as -->
      <clip id="IntuitionWidget" class="Intuition">
        <frame/>
      </clip>
    </library>

    <!-- Widget is placed via attachMovie() in Intuition.main() -->
  </frame>
</movie>
